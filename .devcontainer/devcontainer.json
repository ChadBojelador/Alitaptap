// For format details, see https://aka.ms/devcontainer.json
{
	"name": "Alitaptap Dev",
	"image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
	"forwardPorts": [8000],
	"portsAttributes": {
		"8000": {
			"label": "FastAPI",
			"onAutoForward": "openPreview"
		}
	},
	"postCreateCommand": "python -m pip install --upgrade pip && pip install -r services/api_fastapi/requirements-dev.txt",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"dart-code.dart-code",
				"dart-code.flutter",
				"ms-azuretools.vscode-docker"
			]
		}
	}
}
