# ALITAPTAP FastAPI Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env or the service account JSON to git.

# Firebase
FIREBASE_PROJECT_ID=alitaptap-500c9
FIREBASE_SERVICE_ACCOUNT_PATH=secrets/service-account.json
FIREBASE_STORAGE_BUCKET=alitaptap-500c9.appspot.com

# HuggingFace model for semantic matching (no API key needed — runs locally)
HUGGINGFACE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# App
APP_ENV=dev
APP_PORT=8000

# ---------------------------------------------------------------------------
# AI Integration (leave empty until ready to integrate)
# ---------------------------------------------------------------------------

# Option A: OpenAI API key — for title suggestions and issue validation
# OPENAI_API_KEY=sk-...

# Option B: HuggingFace Inference API key — for SDG tagging
# HUGGINGFACE_API_KEY=hf_...

# AI feature flags — set to true to enable each AI service
# When false, services use stubs/heuristics (safe default)
AI_TITLE_SUGGESTIONS_ENABLED=false
AI_SDG_TAGGING_ENABLED=false
AI_ISSUE_VALIDATION_ENABLED=false
