# ── Railway sets this automatically when you add a MySQL plugin ──
DATABASE_URL=mysql://user:password@host:port/dbname

# ── App URLs (set to your Railway public domain after deploy) ──
APP_URL=https://your-app.up.railway.app
FRONTEND_URL=https://your-app.up.railway.app
GOOGLE_CALLBACK_URL=https://your-app.up.railway.app/auth/google/callback

# ── Auth secrets (generate strong random strings) ──
JWT_SECRET=replace_with_strong_random_secret
SESSION_SECRET=replace_with_another_strong_random_secret

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Python AI agents ──
GROQ_API_KEY=your_groq_api_key
SERPER_API_KEY=your_serper_api_key

# ── Optional ──
PORT=3000
NODE_ENV=production
